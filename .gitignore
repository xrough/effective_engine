# Root CMake build directory (market_maker + artifacts)
/build/
cmake-build-*/

# demo/build: ignore CMake artifacts and compiled binaries; results/ is tracked
demo/build/CMakeFiles/
demo/build/CMakeCache.txt
demo/build/cmake_install.cmake
demo/build/Makefile
demo/build/*.cmake
demo/build/compile_commands.json
demo/build/alpha_pnl_test_runner
demo/build/alpha_runner
demo/build/demo_runner
# Training data and model checkpoints (large; regenerate with trainer.py)
demo/build/artifacts/training_*/
demo/build/artifacts/checkpoints/

# Compiled object files and libraries
*.o
*.a
*.so
*.dylib
*.exe
market_maker

# IDE / 编辑器
.vscode/
.idea/
*.user
*.xcodeproj/
*.xcworkspace/
.DS_Store

# Claude Code 会话目录（本地专用，不提交）
.claude/
CLAUDE.md
AGENTS.md

# Local reference docs (not for version control)
structure.md

# 编译命令数据库（由 CMake 生成，本地专用）
compile_commands.json

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.venv/
venv/

# 笔记
notes/

# data
demo/data/